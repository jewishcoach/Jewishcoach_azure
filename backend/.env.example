# Backend environment (copy to `.env` locally; set equivalents in Azure App Service → Configuration)

# --- Email sending (required for onboarding drip + calendar reminders) ---
# Option A — Azure Communication Services Email:
# EMAIL_CONNECTION_STRING=endpoint=https://....communication.azure.com/;accesskey=...

# Option B — SendGrid:
# SENDGRID_API_KEY=SG....

# MAIL FROM must match a verified domain on your Email resource:
# - ACS with Azure-managed domain only: use MailFrom from Portal, e.g.
#   EMAIL_SENDER=donotreply@xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx.azurecomm.net
# - ACS with custom domain jewishcoacher.com: verify domain + DNS (SPF/DKIM), then add sender username in ACS (e.g. support):
#   EMAIL_SENDER=Jewish Coach Support <support@jewishcoacher.com>
#   (Same requirement as any MAIL FROM: the exact address must be verified on the Email resource.)
# - SendGrid: use a verified sender/domain for EMAIL_SENDER.

# Force inbound support auto-reply without toggling admin UI (optional).
# Empty = use DB flag auto_reply_enabled. true|false also accepts 1/0 yes/no on/off.
# SUPPORT_AUTO_REPLY_ENABLED=true

# While EMAIL_SENDER uses *.azurecomm.net, Reply-To defaults to SUPPORT_INBOUND_MAILBOX
# (below) so recipients' "Reply" goes to support — unless you set EMAIL_REPLY_TO explicitly.
# SUPPORT_INBOUND_MAILBOX=support@jewishcoacher.com

# Optional — overrides the default Reply-To (including the support fallback above):
# EMAIL_REPLY_TO=support@jewishcoacher.com
# EMAIL_REPLY_TO_DISPLAY_NAME=Jewish Coach · Support

# Legacy example — personal Reply-To when MAIL FROM is already your verified domain:
# EMAIL_REPLY_TO=you@jewishcoacher.com

# Used for {{app_url}} in onboarding templates:
PUBLIC_APP_URL=https://jewishcoacher.com

# Resolve real user emails from Clerk (recommended for delivering to new signups):
# CLERK_SECRET_KEY=sk_live_...

# --- Automated onboarding dispatch (optional but recommended in production) ---
# Generate a long random string. Set the SAME value as GitHub Actions secret ONBOARDING_EMAIL_CRON_SECRET.
# GitHub workflow calls POST .../api/internal/onboarding-email/process-due with header X-Onboarding-Email-Cron-Secret.
# ONBOARDING_EMAIL_CRON_SECRET=

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# יציבות ריבוי משתמשים (פרודקשן): PostgreSQL ב-Azure — מדריך בעברית:
#   backend/docs/MULTIUSER_SETUP_HE.md
# סקריפט CLI שמקים Postgres ומחבר את jewishcoach-api (מהשורש של הריפו):
#   export AZURE_PG_ADMIN_PASSWORD='…לפחות-12-תווים…'
#   bash scripts/azure_enable_postgres_for_multiuser.sh
#
# SQLite — ברירת מחדל לפיתוח מקומי:
# DATABASE_URL=sqlite:///./coaching.db
#
# SQLite — קובץ במסלול מוחלט בשרת (ארבעה slashes אחרי sqlite://):
# DATABASE_URL=sqlite:////home/site/wwwroot/coaching.db
#
# Azure Database for PostgreSQL (Flexible Server) — חובה sslmode=require בדרך כלל:
# DATABASE_URL=postgresql+psycopg2://ADMIN:PASSWORD@HOST.postgres.database.azure.com:5432/DBNAME?sslmode=require
#
# הערה: אם שם המשתמש של Azure כולל תווים מיוחדים — קודדו לפי כללי URL (למשל %40 במקום @ בשם המשתמש כשנדרש).
#
# כיוון בריכת חיבורים ל-PostgreSQL (אופציונלי; ברירות מחדל שמרניות ל-B1ms):
# DB_POOL_SIZE=3
# DB_MAX_OVERFLOW=5
# GUNICORN_WORKERS=2
# תקציב חיבורים ≈ GUNICORN_WORKERS × (DB_POOL_SIZE + DB_MAX_OVERFLOW) — השאירו מרווח ל-superuser/migrations.
# DB_POOL_TIMEOUT=30
# DB_POOL_RECYCLE_SEC=280
#
# SQLite — timeout להמתנה על נעילה (שניות, אופציונלי):
# SQLITE_BUSY_TIMEOUT_SEC=30
#
# העברת נתונים חד-פעמית SQLite → Postgres (הרס נתונים ביעד — גיבוי לפני):
# SOURCE_DATABASE_URL=sqlite:////path/to/coaching.db
# CONFIRM_SQLITE_TO_PG_COPY=YES
# PYTHONPATH=. python3 scripts/sqlite_to_postgres.py --dry-run
# PYTHONPATH=. python3 scripts/sqlite_to_postgres.py -v
#
# תיעוד מלא: backend/docs/POSTGRESQL_AZURE_RUNBOOK.md

# --- Rate limits (SlowAPI) shared across workers / instances (optional) ---
# Without Redis, each process keeps its own counters (under-counting under load).
# SlowAPI env name:
# RATELIMIT_STORAGE_URL=redis://localhost:6379/0
# Alias (either works if set):
# REDIS_URL=redis://localhost:6379/0
# Azure Cache for Redis (TLS):
# RATELIMIT_STORAGE_URL=rediss://:ACCESS_KEY@HOST.redis.cache.windows.net:6380/0

# --- PayMe (Israel) — Hosted Fields checkout + POST /generate-sale on backend ---
# API key from PayMe merchant dashboard (set in Azure App Service → Configuration; never commit).
# PAYME_API_KEY=
# PAYME_SELLER_PAYME_ID=
# If unset, seller_payme_id for REST falls back to PAYME_API_KEY (works for many merchants).
# Payments API base (PayMe docs): Staging https://sandbox.payme.io/api/ | Production https://live.payme.io/api/
# PAYME_PAYMENTS_API_BASE=https://sandbox.payme.io/api
# Optional: if PayMe supplies a webhook signing secret for POST callbacks.
# PAYME_WEBHOOK_SECRET=
